{
  "name": "wanderpage",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.13.1",
  "engines": {
    "node": ">=20.9"
  },
  "scripts": {
    "dev": "next dev",
    "studio": "tsx scripts/studio.ts",
    "build": "next build",
    "preview": "serve out",
    "trip": "tsx scripts/trip.ts",
    "trip:demo": "tsx scripts/trip.ts --demo",
    "trip:list": "tsx scripts/trip-publish.ts list",
    "trip:publish": "tsx scripts/trip-publish.ts publish",
    "trip:unpublish": "tsx scripts/trip-publish.ts unpublish",
    "deploy": "tsx scripts/deploy.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "test": "vitest run",
    "test:live": "WANDERPAGE_LIVE_TEST=1 vitest run tests/live/openai-photo-folder.test.ts",
    "test:e2e": "playwright test",
    "privacy": "tsx scripts/privacy-check.ts",
    "check": "pnpm typecheck && pnpm lint && pnpm test && pnpm trip:demo && pnpm build && pnpm privacy && pnpm test:e2e",
    "prepare": "husky",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint:fix": "eslint . --fix",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:fast": "vitest run --exclude tests/integration/** --exclude tests/live/**",
    "test:comprehensive": "pnpm check",
    "security:audit": "pnpm audit --audit-level high",
    "security:config": "npx create-qa-architect@latest --security-config",
    "type-check": "tsc --noEmit",
    "type-check:all": "pnpm typecheck",
    "quality:check": "pnpm check",
    "quality:ci": "pnpm check && pnpm security:audit"
  },
  "dependencies": {
    "commander": "latest",
    "exifr": "latest",
    "motion": "latest",
    "next": "latest",
    "openai": "latest",
    "p-limit": "latest",
    "react": "latest",
    "react-dom": "latest",
    "sharp": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@eslint/eslintrc": "latest",
    "@playwright/test": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "eslint": "^9.39.1",
    "eslint-config-next": "latest",
    "jsdom": "latest",
    "serve": "latest",
    "tsx": "latest",
    "typescript": "^5.9.3",
    "vitest": "latest",
    "@commitlint/cli": "latest",
    "@commitlint/config-conventional": "latest",
    "@vitest/coverage-v8": "latest",
    "husky": "latest",
    "lint-staged": "^16.4.0",
    "prettier": "latest"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,json,md,yml,yaml}": "prettier --write"
  },
  "volta": {
    "node": "22.22.2"
  }
}
